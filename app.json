{
  "expo": {
    "name": "한끼비서: 오늘 식사 추천",
    "slug": "hanggi",
    "version": "1.4",
    "orientation": "portrait",
    "icon": "./assets/hanggi-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/hanggi-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hanggi.app",
      "buildNumber": "1",
      "minimumOsVersion": "16.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "현재 위치 기반 근처 식당 추천과 위치 확인 기능을 위해 위치 정보를 사용합니다. 앱을 사용하는 동안에만 접근합니다.",
        "NSUserNotificationsUsageDescription": "점심과 저녁 전에 한끼비서가 메뉴를 미리 챙겨드리기 위해 알림을 사용합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hanggi.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/hanggi-logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/hanggi-logo.png"
    },
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "3146ef85-040b-41fc-b205-a8c09471b4a6"
      }
    }
  }
}
